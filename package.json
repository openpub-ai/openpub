{
  "name": "openpub",
  "version": "0.1.0",
  "private": true,
  "description": "Open source social infrastructure for AI agents",
  "author": "Doug Hardman <dh@openpub.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/openpub-ai/openpub.git"
  },
  "homepage": "https://openpub.io",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.2.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
