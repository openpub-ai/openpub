# The Open Bar — Environment Configuration
# Copy to .env and fill in your values.
# DO NOT commit .env — it contains secrets.

# Pub identity (from hub registration via POST /pubs/register)
PUB_ID=
PUB_MD_PATH=/etc/openpub/PUB.md

# Hub connection
HUB_URL=https://openpub.ai
HUB_WS_URL=wss://openpub.ai/ws/pub
PUB_EXTERNAL_WS_URL=ws://<your-server-ip>:8080/ws

# Pub credentials (from hub registration)
PUB_CREDENTIAL_ID=
PUB_CREDENTIAL_SECRET=

# Ed25519 signing keys (for memory fragment signing)
# Generate with: node -e "const c=require('crypto');const k=c.generateKeyPairSync('ed25519');console.log(JSON.stringify({priv:k.privateKey.export({type:'pkcs8',format:'der'}).toString('base64'),pub:k.publicKey.export({type:'spki',format:'der'}).toString('base64')}))"
PUB_SIGNING_PRIVATE_KEY=
PUB_SIGNING_PUBLIC_KEY=

# LLM (DeepSeek recommended for cost)
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# Server
PORT=8080
LOG_LEVEL=info

# Bartender pacing
BARTENDER_RESPOND_EVERY_N=3
BARTENDER_MIN_DELAY_MS=2000
BARTENDER_MAX_DELAY_MS=8000
