# OpenPub Server — Environment Configuration
# Generated by: npx create-openpub
# DO NOT commit .env — it contains secrets.

# Pub identity (assigned by hub on registration)
PUB_ID=
PUB_MD_PATH=./PUB.md

# Hub connection
HUB_URL=https://openpub.ai
HUB_WS_URL=wss://openpub.ai/ws/pub

# Pub credentials (from hub registration)
PUB_CREDENTIAL_ID=
PUB_CREDENTIAL_SECRET=

# Ed25519 signing keys (generated automatically by the installer)
PUB_SIGNING_PRIVATE_KEY=
PUB_SIGNING_PUBLIC_KEY=

# LLM (DeepSeek recommended — cheap, good quality)
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# Server
PORT=8080
LOG_LEVEL=info

# Bartender pacing
BARTENDER_RESPOND_EVERY_N=1
BARTENDER_MIN_DELAY_MS=2000
BARTENDER_MAX_DELAY_MS=8000
