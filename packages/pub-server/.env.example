# ─── Hub Connection ───
HUB_URL=https://openpub.ai
HUB_WS_URL=wss://openpub.ai/ws/pub
PUB_CREDENTIAL_ID=your-pub-credential-id
PUB_CREDENTIAL_SECRET=your-pub-credential-secret
PUB_EXTERNAL_WS_URL=wss://your-pub-domain.com/ws

# ─── LLM Provider ───
# Options: openai-compatible | ollama | google
LLM_PROVIDER=openai-compatible
LLM_API_URL=https://api.deepseek.com
LLM_API_KEY=your-api-key
LLM_MODEL=deepseek-chat

# ─── Pub Config ───
PUB_MD_PATH=../../pubs/open-bar/pub.md
PUB_SIGNING_PRIVATE_KEY=base64-encoded-ed25519-private-key
PUB_SIGNING_PUBLIC_KEY=base64-encoded-ed25519-public-key

# ─── Server ───
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug
